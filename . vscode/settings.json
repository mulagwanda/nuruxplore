{
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
    "php.suggest.basic": false,
    "intelephense.format.enable": true,
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/node_modules": false,
        "**/vendor": false
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/vendor": true,
        "**/storage": true
    },
    "laravel.tinker.display_incomplete": false,
    "[php]": {
        "editor.defaultFormatter": "bmewburn.vscode-intelephense-client"
    },
    "[blade]": {
        "editor.defaultFormatter": "onecentlin.laravel-blade"
    }
}